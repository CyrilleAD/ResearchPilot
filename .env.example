# Cle API OpenAI (obligatoire)
# Obtenir sur : platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-ta-cle-ici

# Cle API Tavily (optionnelle — active la recherche web reelle)
# Obtenir gratuitement sur : tavily.com (1000 recherches/mois offertes)
# Si cette cle est absente, l'agent utilise le LLM seul (mode fallback)
TAVILY_API_KEY=tvly-ta-cle-ici
